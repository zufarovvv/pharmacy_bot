# Скопируй этот файл в .env и заполни значения.
# .env в git не попадает (см. .gitignore).

# Telegram bot token (получить у @BotFather)
BOT_TOKEN=

# PostgreSQL
DB_USER=
DB_PASS=
DB_NAME=
DB_HOST=localhost

# Google Sheet с дашбордами аптек (один лист = одна аптека).
# Берётся из URL: https://docs.google.com/spreadsheets/d/<ID>/edit
DASHBOARD_SHEET_ID=

# Google service account JSON. По умолчанию ./creds.json.
GOOGLE_CREDS_FILE=creds.json

# Старый Sheet с мастер-данными (для screenshot.py / update_inn_in_sheet)
SHEET_ID=
DATA_SHEET_GID=0
REPORT_SHEET_GID=

# Telegram chat/channel ID, куда бот пересылает отзывы пользователей
FEEDBACK_CHANNEL_ID=

# Публичный URL Telegram Mini App (ngrok в dev, https://... в проде)
WEB_APP_URL=

# Порт aiohttp-сервера (раздаёт webapp/ и /api/me)
API_PORT=8080

# DEV ONLY: разрешить ?tg_id= в URL без подписи Telegram.
# В проде ОБЯЗАТЕЛЬНО 0 — иначе любой может прочитать чужую аптеку.
ALLOW_QUERY_TG_ID=0

# AI-ассистент (Anthropic Claude). Если пусто — режим "Спросить AI" отключён
# в Mini App, остаётся только статичный FAQ.
# Получить ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Модель Claude. Дешёвая и быстрая — Haiku. Качественнее (дороже) — Sonnet.
ANTHROPIC_MODEL=claude-haiku-4-5

# Логирование: 1 — print() уходит в logs/bot.log (терминал чистый),
# 0 — print() показывается в терминале как раньше (удобно при дебаге).
LOG_TO_FILE=1
